# Local development — copy to .env and fill in values.
# Production: set these in the Render dashboard (or your host), never commit .env.

PORT=8000
NODE_ENV=development

# MongoDB — pick ONE style:
#
# A) Single line (password must be URL-encoded if it contains @ # : / ? & etc.)
# MONGODB_URI=mongodb+srv://USER:ENCODED_PASSWORD@cluster0.YOUR_HOST.mongodb.net/spardha?retryWrites=true&w=majority
#
# B) Same Atlas user/cluster, plain password (no encoding needed). Omit MONGODB_URI when using this.
# MONGODB_USER=my_db_user
# MONGODB_PASSWORD=your_plain_password_from_atlas
# MONGODB_HOST=cluster0.YOUR_HOST.mongodb.net
# MONGODB_DB_NAME=spardha
# MONGODB_QUERY_STRING=retryWrites=true&w=majority
#
# If you see "bad auth": Atlas → Database Access → edit the SAME user (no new user) → reset password → update env.
# Network Access: allow your IP or 0.0.0.0/0 for dev.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.YOUR_HOST.mongodb.net/spardha?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_string_in_production
# Optional — token expiry is currently hardcoded to 7d in code; keep for future use.
JWT_EXPIRE=7d

# Browser origins allowed to call the API (CORS). Use scheme + host only (no /signin path).
# Trailing paths are stripped when parsing, but prefer https://your-app.vercel.app
# Single app:
#   FRONTEND_URL=https://your-app.vercel.app
# Multiple origins (production + preview + local), comma-separated, no spaces:
#   FRONTEND_URL=https://app.vercel.app,https://app-git-main-user.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173
