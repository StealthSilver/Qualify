# Local development — copy to .env and fill in values.
# Production: set these in the Render dashboard (or your host), never commit .env.

PORT=8000
NODE_ENV=development

# MongoDB Atlas (or other). For Atlas: allow network access for Render (0.0.0.0/0 or Render static outbound IPs).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/spardha?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_string_in_production
# Optional — token expiry is currently hardcoded to 7d in code; keep for future use.
JWT_EXPIRE=7d

# Browser origins allowed to call the API (CORS). No trailing slash.
# Single app:
#   FRONTEND_URL=https://your-app.vercel.app
# Multiple (e.g. production + preview + local), comma-separated:
#   FRONTEND_URL=https://app.vercel.app,https://*.vercel.app,http://localhost:5173
#
# Note: wildcard subdomains like https://*.vercel.app are NOT supported by the cors package;
# add each Vercel preview URL you need, or use a single production frontend URL only.
FRONTEND_URL=http://localhost:5173
