# Vite exposes only variables prefixed with VITE_.
# Copy to .env for local dev. On Vercel, add the same variable in Project → Settings → Environment Variables.

# Public backend API base URL (must include /api — matches Express mount at /api)
# Local:
#   VITE_API_URL=http://localhost:8000/api
# Production (replace with your Render service URL):
#   VITE_API_URL=https://spardha-api.onrender.com/api
VITE_API_URL=http://localhost:8000/api
